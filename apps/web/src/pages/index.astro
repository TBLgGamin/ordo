---
import Layout from "@/layouts/Layout.astro"
import Header from "@/components/Header.astro"
import Hero from "@/components/Hero.astro"
import AgentStrip from "@/components/AgentStrip.astro"
import Features from "@/components/Features.astro"
import Orchestration from "@/components/Orchestration.astro"
import Sessions from "@/components/Sessions.astro"
import Cli from "@/components/Cli.astro"
import Install from "@/components/Install.astro"
import Footer from "@/components/Footer.astro"
---

<Layout
	title="ordo | a tiling terminal multiplexer for Windows"
	description="ordo tiles your shells around you in real windows and keeps every one alive in a daemon that survives closed windows and reboots. Run an AI agent in a pane and it gets wired in over MCP automatically. Windows Terminal, one-command install."
>
	<Header />
	<main>
		<Hero />
		<Features />
		<Sessions />
		<Cli />
		<AgentStrip />
		<Orchestration />
		<Install />
	</main>
	<Footer />
</Layout>
