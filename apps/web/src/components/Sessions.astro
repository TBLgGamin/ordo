---
import SectionHeading from "@/components/SectionHeading.astro"
import ProductShot from "@/components/ProductShot.astro"

const points = [
	{
		step: "01",
		title: "Warm restore",
		description: "Reopen a session while the daemon lives and every pane reattaches to its still-running shell. Nothing restarts, nothing is lost.",
	},
	{
		step: "02",
		title: "Cold restore",
		description: "After a reboot, panes are rebuilt from captured scrollback and working directories, and the program that was running is launched again.",
	},
	{
		step: "03",
		title: "Names with rank",
		description: "Every session gets a stable Roman id like centurion-optio, and a local model writes the human title from what is on screen.",
	},
]
---

<section id="sessions" class="overflow-hidden bg-hero px-6 py-24 sm:px-8">
	<div class="mx-auto w-full max-w-[88rem]">
		<div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
			<div class="flex items-center lg:order-2">
				<ProductShot
					src="/product/session-restore.png"
					alt="Ordo restoring a saved terminal session with the command center and four tiled Windows Terminal panes reattached."
					class="-mx-6 sm:mx-0 lg:w-[118%] lg:max-w-none"
				/>
			</div>
			<div class="lg:order-1">
				<SectionHeading eyebrow="persistence" title="Close everything. Lose nothing.">
					<p>
						Your shells do not live in the windows. They live in a hidden daemon that keeps
						running after every window is gone. A closed window is just a detached one.
					</p>
				</SectionHeading>
				<dl class="mt-10 flex flex-col gap-8">
					{points.map((point) => (
						<div class="flex gap-5">
							<span class="text-2xl leading-none font-semibold text-arch-ink dark:text-arch">{point.step}</span>
							<div>
								<dt class="font-medium text-ink">{point.title}</dt>
								<dd class="mt-1.5 max-w-md text-sm leading-relaxed text-stone">{point.description}</dd>
							</div>
						</div>
					))}
				</dl>
			</div>
		</div>
	</div>
</section>
