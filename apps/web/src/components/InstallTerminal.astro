---
import CopyButton from "@/components/CopyButton.vue"
import { highlightTerminalCode } from "@/lib/highlight"

const PS = "irm https://raw.githubusercontent.com/TBLgGamin/ordo/master/scripts/install.ps1 | iex"
const SH = "curl -fsSL https://raw.githubusercontent.com/TBLgGamin/ordo/master/scripts/install.sh | bash"

const tabs = await Promise.all([
	{
		id: "windows",
		label: "Windows",
		command: PS,
		prompt: "PS>",
		lang: "powershell" as const,
	},
	{
		id: "macos",
		label: "macOS",
		command: SH,
		prompt: "$",
		lang: "shellscript" as const,
	},
	{
		id: "linux",
		label: "Linux",
		command: SH,
		prompt: "$",
		lang: "shellscript" as const,
	},
].map(async (tab) => ({
	...tab,
	highlighted: await highlightTerminalCode(tab.command, tab.lang),
})))
---

<div class="w-full" data-install-terminal>
	<div class="mb-2 flex gap-1" role="tablist" aria-label="Install command">
		{tabs.map((tab, index) => (
			<button
				type="button"
				role="tab"
				aria-selected={index === 0 ? "true" : "false"}
				data-install-tab={tab.id}
				class:list={[
					"rounded-md px-3 py-1 text-xs font-medium transition-colors",
					index === 0 ? "bg-pine-deep text-zinc-100" : "text-stone hover:text-ink",
				]}
			>
				{tab.label}
			</button>
		))}
	</div>

	<div class="overflow-hidden rounded-lg bg-pine-deep text-zinc-100 shadow-xl shadow-black/10 ring-1 ring-white/10">
		<div class="flex min-h-10 items-center gap-2 border-b border-white/10 px-3 sm:px-4">
			<span class="size-2.5 rounded-full bg-[#ff5f57]"></span>
			<span class="size-2.5 rounded-full bg-[#ffbd2e]"></span>
			<span class="size-2.5 rounded-full bg-[#28c840]"></span>
			<span class="ml-2 min-w-0 truncate font-mono text-xs text-zinc-500">install ordo</span>
			<div class="ml-auto">
				{tabs.map((tab, index) => (
					<div data-install-copy={tab.id} class:list={[index !== 0 && "hidden"]}>
						<CopyButton client:load text={tab.command} />
					</div>
				))}
			</div>
		</div>

		<div class="min-w-0">
			{tabs.map((tab, index) => (
				<div data-install-panel={tab.id} class:list={[index !== 0 && "hidden"]}>
					<div class="flex min-w-0 items-start gap-3 overflow-x-auto px-4 py-3">
						<span class="select-none pt-[0.1rem] font-mono text-sm text-arch">{tab.prompt}</span>
						<div class="terminal-code min-w-0 flex-1" set:html={tab.highlighted} />
					</div>
				</div>
			))}
		</div>
	</div>
</div>

<script>
	const roots = document.querySelectorAll("[data-install-terminal]")

	function detectOs() {
		const hint = `${navigator.platform ?? ""} ${navigator.userAgent ?? ""}`.toLowerCase()
		if (hint.includes("mac") || hint.includes("iphone") || hint.includes("ipad")) return "macos"
		if (hint.includes("linux") || hint.includes("android")) return "linux"
		return "windows"
	}

	function setActive(root, id) {
		root.querySelectorAll("[data-install-tab]").forEach((tab) => {
			const active = tab.getAttribute("data-install-tab") === id
			tab.setAttribute("aria-selected", String(active))
			tab.classList.toggle("bg-pine-deep", active)
			tab.classList.toggle("text-zinc-100", active)
			tab.classList.toggle("text-stone", !active)
			tab.classList.toggle("hover:text-ink", !active)
		})

		root.querySelectorAll("[data-install-panel]").forEach((panel) => {
			panel.classList.toggle("hidden", panel.getAttribute("data-install-panel") !== id)
		})

		root.querySelectorAll("[data-install-copy]").forEach((copy) => {
			copy.classList.toggle("hidden", copy.getAttribute("data-install-copy") !== id)
		})
	}

	for (const root of roots) {
		setActive(root, detectOs())
		root.querySelectorAll("[data-install-tab]").forEach((tab) => {
			tab.addEventListener("click", () => {
				const id = tab.getAttribute("data-install-tab")
				if (id) setActive(root, id)
			})
		})
	}
</script>
