---
import { Button } from "@/components/ui/button"
import { Separator } from "@/components/ui/separator"
import SectionHeading from "@/components/SectionHeading.astro"
import CopyCommand from "@/components/CopyCommand.vue"

const installCommand = "irm https://raw.githubusercontent.com/TBLgGamin/ordo/master/scripts/install.ps1 | iex"

const steps = [
	{
		step: "01",
		title: "Run the installer",
		description: "One PowerShell command fetches ordo and checks its prerequisites for you.",
	},
	{
		step: "02",
		title: "Type ordo",
		description: "The launcher opens in a fresh window with your saved sessions ready to restore.",
	},
	{
		step: "03",
		title: "Spawn your agents",
		description: "Add panes from the launcher or run ordo spawn — they tile into formation and get their MCP radio automatically.",
	},
]
---

<section id="install">
	<div class="mx-auto w-full max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
		<div class="mx-auto flex max-w-3xl flex-col items-center gap-10 text-center">
			<SectionHeading eyebrow="install" title="Deployed in under a minute." class="flex max-w-none flex-col items-center">
				<p>
					Requires Windows 11 with Windows Terminal. The installer tells you if anything is
					missing.
				</p>
			</SectionHeading>
			<CopyCommand client:load command={installCommand} prompt="PS>" />
			<div class="grid w-full gap-6 text-left sm:grid-cols-3">
				{steps.map((item) => (
					<div class="flex flex-col gap-2">
						<span class="font-mono text-sm font-bold text-primary">{item.step}</span>
						<Separator class="bg-primary/30" />
						<h3 class="font-semibold">{item.title}</h3>
						<p class="text-sm text-muted-foreground">{item.description}</p>
					</div>
				))}
			</div>
			<Button variant="outline" size="lg" as="a" href="https://github.com/TBLgGamin/ordo">
				Read the source on GitHub
			</Button>
		</div>
	</div>
</section>
