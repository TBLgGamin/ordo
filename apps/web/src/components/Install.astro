---
import { Button } from "@/components/ui/button"
import CopyCommand from "@/components/CopyCommand.vue"
import SectionHeading from "@/components/SectionHeading.astro"

const installCommand = "irm https://raw.githubusercontent.com/TBLgGamin/ordo/master/scripts/install.ps1 | iex"

const steps = [
	{
		step: "01",
		title: "Run the installer",
		description: "One PowerShell command fetches ordo and checks its prerequisites for you.",
	},
	{
		step: "02",
		title: "Type ordo",
		description: "The launcher opens in a fresh window with your saved sessions ready to restore.",
	},
	{
		step: "03",
		title: "Spawn your panes",
		description: "Add shells or agents from the launcher or with ordo spawn. They tile into formation, and agents get their MCP radio automatically.",
	},
]
---

<section id="install" class="relative overflow-hidden bg-hero px-6 py-28 sm:px-8">
	<div class="relative mx-auto flex w-full max-w-3xl flex-col items-center gap-12 text-center">
		<SectionHeading eyebrow="install" title="Deployed in under a minute." class="flex max-w-none flex-col items-center">
			<p>
				Requires Windows 11 with Windows Terminal. The installer tells you if anything is
				missing.
			</p>
		</SectionHeading>
		<div class="w-full max-w-2xl">
			<CopyCommand client:load command={installCommand} prompt="PS>" />
		</div>
		<div class="grid w-full gap-10 text-left sm:grid-cols-3">
			{steps.map((item) => (
				<div class="flex flex-col gap-3">
					<span class="text-3xl leading-none font-semibold text-arch-ink dark:text-arch">{item.step}</span>
					<h3 class="font-medium text-ink">{item.title}</h3>
					<p class="text-sm leading-relaxed text-stone">{item.description}</p>
				</div>
			))}
		</div>
		<Button variant="outline" size="lg" as="a" href="https://github.com/TBLgGamin/ordo" class="rounded-lg px-6">
			Read the source on GitHub
		</Button>
	</div>
</section>
