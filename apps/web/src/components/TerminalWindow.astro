---
interface Props {
	title: string
	class?: string
}

const { title, class: className } = Astro.props
---

<div class:list={["overflow-hidden rounded-2xl bg-pine-deep text-zinc-100 shadow-xl shadow-black/10 ring-1 ring-white/10", className]}>
	<div class="flex items-center gap-2 border-b border-white/10 px-4 py-2.5">
		<span class="size-2.5 rounded-full bg-white/15"></span>
		<span class="size-2.5 rounded-full bg-white/15"></span>
		<span class="size-2.5 rounded-full bg-arch"></span>
		<span class="ml-2 font-mono text-xs text-zinc-500">{title}</span>
	</div>
	<div class="overflow-x-auto p-4 font-mono text-[0.8rem] leading-relaxed sm:text-sm">
		<slot />
	</div>
</div>
