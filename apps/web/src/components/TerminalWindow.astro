---
interface Props {
	title: string
	class?: string
}

const { title, class: className } = Astro.props
---

<div class:list={["overflow-hidden rounded-xl border bg-card", className]}>
	<div class="flex items-center gap-2 border-b bg-secondary/60 px-4 py-2.5">
		<span class="size-2.5 rounded-full bg-border"></span>
		<span class="size-2.5 rounded-full bg-border"></span>
		<span class="size-2.5 rounded-full bg-primary/70"></span>
		<span class="ml-2 font-mono text-xs text-muted-foreground">{title}</span>
	</div>
	<div class="overflow-x-auto p-4 font-mono text-[0.8rem] leading-relaxed sm:text-sm">
		<slot />
	</div>
</div>
