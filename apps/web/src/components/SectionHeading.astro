---
interface Props {
	eyebrow: string
	title: string
	class?: string
}

const { eyebrow, title, class: className } = Astro.props
---

<div class:list={["max-w-2xl", className]}>
	<p class="font-mono text-xs uppercase tracking-[0.3em] text-primary">{eyebrow}</p>
	<h2 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl">{title}</h2>
	<div class="mt-4 text-base text-muted-foreground sm:text-lg">
		<slot />
	</div>
</div>
