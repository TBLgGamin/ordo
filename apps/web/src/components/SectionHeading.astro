---
interface Props {
	eyebrow: string
	title: string
	class?: string
}

const { eyebrow, title, class: className } = Astro.props
---

<div class:list={["max-w-2xl", className]}>
	<p class="text-xs font-medium uppercase tracking-[0.3em] text-stone">{eyebrow}</p>
	<h2 class="mt-4 text-4xl leading-tight font-semibold tracking-tight text-balance text-ink lg:text-5xl">
		{title}
	</h2>
	<div class="mt-6 text-lg leading-relaxed text-stone">
		<slot />
	</div>
</div>
