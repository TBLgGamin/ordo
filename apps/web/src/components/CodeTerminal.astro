---
import { highlightTerminalCode } from "@/lib/highlight"

interface Props {
	code: string
	title: string
	lang?: "shellscript" | "powershell"
	label?: string
	class?: string
}

const { code, title, lang = "shellscript", label, class: className } = Astro.props
const highlighted = await highlightTerminalCode(code, lang)
---

<div class:list={["overflow-hidden rounded-lg bg-pine-deep text-zinc-100 shadow-lg shadow-black/10 ring-1 ring-white/10", className]}>
	<div class="flex min-h-10 items-center gap-2 border-b border-white/10 px-4">
		<span class="size-2.5 rounded-full bg-[#ff5f57]"></span>
		<span class="size-2.5 rounded-full bg-[#ffbd2e]"></span>
		<span class="size-2.5 rounded-full bg-[#28c840]"></span>
		<span class="ml-2 min-w-0 truncate font-mono text-xs text-zinc-500">{title}</span>
		{label && <span class="ml-auto rounded bg-white/5 px-2 py-1 font-mono text-[0.65rem] uppercase tracking-[0.16em] text-zinc-500">{label}</span>}
	</div>
	<div class="terminal-code overflow-x-auto px-4 py-3" set:html={highlighted} />
</div>
