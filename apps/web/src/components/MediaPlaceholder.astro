---
interface Props {
	kind?: "video" | "image"
	label: string
	aspect?: string
	class?: string
}

const { kind = "video", label, aspect = "aspect-video", class: className } = Astro.props
---

<div class:list={["relative overflow-hidden rounded-xl border border-dashed bg-card", aspect, className]}>
	<div class="absolute inset-0 flex flex-col items-center justify-center gap-3 p-6 text-center">
		{
			kind === "video" ? (
				<svg class="size-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="2" y="4" width="20" height="16" rx="2" />
					<path d="m10 9 5 3-5 3z" />
				</svg>
			) : (
				<svg class="size-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="3" y="3" width="18" height="18" rx="2" />
					<circle cx="9" cy="9" r="2" />
					<path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21" />
				</svg>
			)
		}
		<span class="font-mono text-[0.65rem] uppercase tracking-[0.25em] text-primary">{kind} placeholder</span>
		<p class="max-w-lg text-sm text-muted-foreground">{label}</p>
	</div>
</div>
