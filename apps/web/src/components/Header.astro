---
import { Button } from "@/components/ui/button"
import ThemeToggle from "@/components/ThemeToggle.vue"

const links = [
	{ href: "/#features", label: "Features" },
	{ href: "/#sessions", label: "Sessions" },
	{ href: "/#orchestration", label: "Agents" },
	{ href: "/docs", label: "Docs" },
	{ href: "/#install", label: "Install" },
]
---

<header class="sticky top-0 z-50 bg-hero/80 backdrop-blur-md">
	<div class="mx-auto flex h-16 w-full max-w-[88rem] items-center justify-between px-6 sm:px-8">
		<a href="/" class="flex items-center gap-2.5 text-ink">
			<img src="/brand/ordo-mark.png" alt="" class="h-8 w-8 object-contain dark:invert" loading="eager" decoding="async" />
		</a>
		<nav class="hidden items-center gap-8 md:flex">
			{links.map((link) => (
				<a href={link.href} class="text-sm text-stone transition-colors hover:text-ink">{link.label}</a>
			))}
		</nav>
		<div class="flex items-center gap-1">
			<Button variant="ghost" size="sm" as="a" href="https://github.com/TBLgGamin/ordo" class="text-stone hover:text-ink">
				<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1.17-.02-2.12-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.02 1.76 2.69 1.25 3.35.95.1-.75.4-1.25.72-1.54-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 2.9-.39c.98 0 1.97.13 2.9.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.06.78 2.14 0 1.55-.01 2.79-.01 3.17 0 .31.21.67.8.56A10.52 10.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z" />
				</svg>
				GitHub
			</Button>
			<ThemeToggle client:load />
		</div>
	</div>
</header>
