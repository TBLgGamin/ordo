---
import SectionHeading from "@/components/SectionHeading.astro"
import ProductShot from "@/components/ProductShot.astro"
---

<section id="cli" class="overflow-hidden bg-hero px-6 py-24 sm:px-8">
	<div class="mx-auto w-full max-w-[88rem]">
		<div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
			<div>
				<SectionHeading eyebrow="cli" title="Scriptable down to the last pane.">
					<p>
						The launcher is optional. Every capability is a plain subcommand you can call from
						any shell, pipe into scripts, or hand to CI, with tab completion for PowerShell,
						bash, and zsh.
					</p>
				</SectionHeading>
			</div>
			<ProductShot
				src="/product/launcher-cli.png"
				alt="Ordo launcher TUI showing saved sessions and live log input."
				class="-mx-6 sm:mx-0 lg:w-[118%] lg:max-w-none"
			/>
		</div>
	</div>
</section>
