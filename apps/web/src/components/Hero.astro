---
import { Button } from "@/components/ui/button"
import DotField from "@/components/DotField.vue"
import InstallTerminal from "@/components/InstallTerminal.astro"
import ProductShot from "@/components/ProductShot.astro"
---

<section id="top" class="relative flex min-h-[calc(100dvh-4rem)] items-center overflow-hidden bg-hero">
	<div class="pointer-events-none absolute inset-y-0 right-0 z-0 hidden w-1/2 items-center justify-center lg:flex">
		<div class="absolute bottom-0 left-1/2 h-[82%] w-[380px] -translate-x-1/2 rounded-t-full bg-arch"></div>
		<DotField
			client:idle
			class="absolute top-[9%] left-1/2 z-10 h-24 w-32 -translate-x-1/2"
			shapes={["circle", "ring", "diamond"]}
			morph="random"
			color="#4a3f7a"
			opacity={0.85}
		/>
		<DotField
			client:idle
			class="absolute top-[16%] left-[10%] h-28 w-24"
			shapes={["rect", "cross", "triangle"]}
			morph="random"
			opacity={0.95}
		/>
		<DotField
			client:idle
			class="absolute top-[30%] right-[7%] h-28 w-24"
			shapes={["diamond", "circle", "ring"]}
			morph="random"
			opacity={0.95}
		/>
		<DotField
			client:idle
			class="absolute bottom-[9%] left-[12%] h-20 w-24"
			shapes={["circle", "ring", "diamond"]}
			morph="random"
			opacity={0.9}
		/>
		<DotField
			client:idle
			class="absolute right-[9%] bottom-[11%] h-20 w-24"
			shapes={["cross", "diamond", "circle"]}
			morph="random"
			opacity={0.9}
		/>
		<ProductShot
			src="/product/hero-formation.png"
			alt=""
			loading="eager"
			class="relative w-[52rem] max-w-[118%]"
			imageClass="select-none"
		/>
	</div>

	<div class="relative z-10 mx-auto w-full max-w-[88rem] px-6 sm:px-8">
		<div class="max-w-xl py-16 lg:py-10">
			<h1 class="text-5xl leading-[1.05] font-semibold tracking-tight text-ink sm:text-6xl lg:text-7xl">
				Bring order to
				<br />
				your terminal
			</h1>
			<p class="mt-7 max-w-md text-lg leading-relaxed text-stone">
				ordo is a tiling terminal multiplexer for Windows, macOS, and Linux. It arranges your
				shells around you in real windows and keeps every one alive in a daemon that outlives
				them. When a pane runs an AI agent, ordo wires it in over MCP so your agents can work
				as a team.
			</p>
			<div class="mt-9 max-w-lg">
				<InstallTerminal />
			</div>
			<div class="mt-6 flex flex-wrap items-center gap-3">
				<Button size="lg" as="a" href="#install" class="rounded-lg px-5">Get started</Button>
				<Button variant="outline" size="lg" as="a" href="/docs" class="rounded-lg px-5">Read the docs</Button>
				<Button variant="ghost" size="lg" as="a" href="https://github.com/TBLgGamin/ordo" class="rounded-lg px-5 text-stone hover:text-ink">
					View on GitHub
				</Button>
			</div>
			<p class="mt-8 text-xs tracking-wide text-stone">
				free &amp; open source &middot; one command install &middot; no cloud required &middot; any terminal &middot; Bun
			</p>
		</div>
	</div>
</section>
