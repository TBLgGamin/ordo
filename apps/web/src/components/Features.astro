---
import DotField from "@/components/DotField.vue"
import SectionHeading from "@/components/SectionHeading.astro"

const features = [
	{
		title: "Tiled, never stacked",
		description: "Panes tile around your terminal in columns and strips. Nothing overlaps, nothing gets buried.",
		icon: `<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>`,
	},
	{
		title: "The formation follows you",
		description: "Drag or resize the center window, even onto another monitor, and every satellite re-tiles around it.",
		icon: `<path d="M12 2v20"/><path d="m15 19-3 3-3-3"/><path d="m19 9 3 3-3 3"/><path d="M2 12h20"/><path d="m5 9-3 3 3 3"/><path d="m9 5 3-3 3 3"/>`,
	},
	{
		title: "Deep agent integration",
		description: "Agents in panes get ordo's MCP tools automatically. One agent can run the whole room.",
		icon: `<path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.2 19.1 19.1"/>`,
	},
	{
		title: "A daemon that keeps watch",
		description: "Shells live in a hidden daemon, not in the window. Close a window and whatever it ran keeps going.",
		icon: `<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>`,
	},
	{
		title: "Restores that actually restore",
		description: "Even after a reboot, every pane comes back with its scrollback, directory and running program.",
		icon: `<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>`,
	},
	{
		title: "Titles itself, locally",
		description: "A tiny local model names each session after what you are doing. No API calls, no cloud.",
		icon: `<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>`,
	},
]
---

<section id="features" class="relative overflow-hidden bg-hero px-6 py-24 sm:px-8">
	<DotField
		client:visible
		class="absolute top-16 right-[6%] hidden h-24 w-28 lg:block"
		shapes={["rect", "circle", "triangle"]}
		morph="random"
		opacity={0.9}
	/>
	<DotField
		client:visible
		class="absolute bottom-16 left-[4%] hidden h-20 w-24 lg:block"
		shapes={["diamond", "circle", "ring"]}
		morph="random"
		opacity={0.85}
	/>
	<div class="relative mx-auto w-full max-w-[88rem]">
		<SectionHeading eyebrow="features" title="A command center, not another tab bar.">
			<p>
				Other multiplexers hide your shells in splits and tabs. ordo gives every shell a real
				window, arranged around you like a formation. Visible, addressable, disposable.
			</p>
		</SectionHeading>

		<div class="mt-16 grid gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
			{features.map((feature) => (
				<div class="flex flex-col gap-2.5">
					<svg
						class="size-5 text-arch-ink dark:text-arch"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
						set:html={feature.icon}
					/>
					<h3 class="text-base font-semibold text-ink">{feature.title}</h3>
					<p class="max-w-xs text-sm leading-relaxed text-stone">{feature.description}</p>
				</div>
			))}
		</div>
	</div>
</section>
