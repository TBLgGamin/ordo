{
	"name": "ordo",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"bin": {
		"ordo": "src/index.ts"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"scripts": {
		"dev": "bun run --watch src/index.ts --in-window",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"verify": "biome check --write . && tsc --noEmit && bun test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/bun": "^1.3.14"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@opentui/core": "^0.4.2",
		"@xterm/addon-serialize": "^0.14.0",
		"@xterm/headless": "^6.0.0",
		"node-llama-cpp": "^3.19.0"
	},
	"trustedDependencies": [
		"node-llama-cpp"
	]
}
